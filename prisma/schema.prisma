// ARQUIVO CRÍTICO: Schema do banco de dados PostgreSQL.
//
// ATENÇÃO MODELO DE IA: Este arquivo define toda a estrutura do banco.
// 1. NUNCA rode 'prisma migrate reset' ou 'prisma db push --force-reset' em produção.
// 2. Use SEMPRE 'prisma migrate deploy' para aplicar migrações seguras.
// 3. NUNCA altere colunas sem criar uma migração versionada.
// 4. Deploy via: python3 /home/ubuntu/omnivoice/deploy-seguro.py
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  name            String            // nome do usuario
  email           String            @unique // login
  password        String            @default("") // hash SHA-256 da senha (vazio para Google OAuth)
  role            String            @default("user") // "admin" ou "user"
  active          Boolean           @default(true)
  googleId        String            @unique @default("") // Google OAuth sub
  freeDownloads   Int               @default(5) // downloads gratuitos restantes
  paymentExempt   Boolean           @default(false) // true = isento de pagamento (download livre)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        Session[]
  payments        Payment[]
  generationQueue GenerationQueue[]
}

model Voice {
  id          String            @id @default(cuid())
  name        String            // e.g. "Ana", "Carlos"
  description String            @default("")
  gender      String            @default("Auto") // male, female, Auto
  age         String            @default("Auto") // child, teenager, young adult, middle-aged, elderly, Auto
  accent      String            @default("Auto") // portuguese accent, american accent, etc
  pitch       String            @default("Auto") // low pitch, moderate pitch, high pitch, etc
  category    String            @default("")
  previewUrl  String            @default("") // URL to preview audio
  order       Int               @default(0)
  active      Boolean           @default(true)
  variations  VoiceVariation[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model VoiceVariation {
  id                String   @id @default(cuid())
  voiceId           String
  label             String   // e.g. "Neutra", "Animada", "Empresarial", "Dramatica", "Sussurrada"
  emoji             String   @default("") // e.g. "😊", "🎉", "💼", "🎭", "🤫"
  refAudioPath      String   @default("") // path on HF Space server (temporary, for Gradio FileData)
  refAudioServerUrl String   @default("") // permanent URL on PHP hosting (for re-upload to HF)
  refAudioFilename  String   @default("") // filename on PHP server (for deletion)
  refAudioName      String   @default("") // original filename (user-friendly)
  refText           String   @default("") // transcription of reference audio
  instruct          String   @default("") // optional instruct for fine-tuning (must use supported values only)
  defaultSpeed      Float    @default(1.0) // speed automatico baseado na analise F0 (vozes graves=1.3/1.4, agudas=1.0)
  order             Int      @default(0)
  active            Boolean  @default(true)
  voice             Voice    @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Track {
  id          String   @id @default(cuid())
  name        String   // e.g. "Corporativo", "Eletronica", "Acustica"
  description String   @default("")
  emoji       String   @default("")
  category    String   @default("")
  audioPath   String   // URL for the track file (PHP hosting)
  duration    Float    @default(0) // duration in seconds
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   // hash SHA-256 do token da sessao
  deviceInfo String   @default("") // User-Agent do dispositivo
  ipAddress  String   @default("") // IP do dispositivo
  createdAt  DateTime @default(now())
  expiresAt  DateTime // quando a sessao expira
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique // e.g. "enableVoiceUpload"
  value String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  externalRef   String   @unique // MercadoPago preference ID / external reference
  status        String   @default("pending") // pending, approved, rejected, cancelled
  amount        Float    @default(1.0)
  format        String   @default("mp3") // mp3 ou wav
  mpPaymentId   String   @default("") // ID do pagamento no MercadoPago
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([externalRef])
  @@index([status])
}

model GenerationQueue {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("waiting") // waiting, processing, completed, failed
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}


// ============================================================
// LOCUTORES OFICIAIS (Banco de Embeddings Pré-Computados)
// ============================================================
model Speaker {
  id          String  @id @default(uuid())
  name        String  // Nome artístico (ex: "Locutor Varejo Impacto")
  avatarUrl   String? // Foto do locutor para o painel
  speakerFile String  @unique  // Nome do arquivo .wav (ex: "aline_dias_locucao_calma.wav") — unico por variacao
  refAudioUrl String  @default("")  // URL real do arquivo no servidor (ex: "http://147.15.77.137/audios/ref/6a179b4e3fc9d_xxx.wav")
  refText     String  @default("")  // Transcricao do audio de referencia (ex: "Bom dia, sua voz esta sendo clonada automaticamente.")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
