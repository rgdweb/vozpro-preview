# OmniVoice TTS - Configuracao Apache (.htaccess)
# Apenas CORS e seguranca basica
# Config PHP esta no .user.ini

# Desabilitar listagem de diretorio
Options -Indexes

# CORS headers para chamadas diretas do browser
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Upload-Token, X-Generate-Token"
</IfModule>

# Seguranca: bloquear acesso direto a arquivos sensiveis via browser
<FilesMatch "^(config\.php|tunnel-config\.ini|uploads\.log|audio_helpers\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear acesso ao .user.ini e .htaccess
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
