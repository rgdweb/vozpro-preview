// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   // nome do usuario
  email     String   @unique // login
  password  String   // hash SHA-256 da senha
  role      String   @default("user") // "admin" ou "user"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Voice {
  id          String            @id @default(cuid())
  name        String            // e.g. "Ana", "Carlos"
  description String            @default("")
  gender      String            @default("Auto") // male, female, Auto
  age         String            @default("Auto") // child, teenager, young adult, middle-aged, elderly, Auto
  accent      String            @default("Auto") // portuguese accent, american accent, etc
  pitch       String            @default("Auto") // low pitch, moderate pitch, high pitch, etc
  category    String            @default("")
  previewUrl  String            @default("") // URL to preview audio
  order       Int               @default(0)
  active      Boolean           @default(true)
  variations  VoiceVariation[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model VoiceVariation {
  id           String   @id @default(cuid())
  voiceId      String
  label        String   // e.g. "Neutra", "Animada", "Empresarial", "Dramática", "Sussurrada"
  emoji        String   @default("") // e.g. "😊", "🎉", "💼", "🎭", "🤫"
  refAudioPath      String   @default("") // path on HF Space server (temporary, for Gradio FileData)
  refAudioServerUrl String   @default("") // permanent URL on PHP hosting (for re-upload to HF)
  refAudioFilename  String   @default("") // filename on PHP server (for deletion)
  refAudioName      String   @default("") // original filename (user-friendly)
  refText      String   @default("") // transcription of reference audio
  instruct     String   @default("") // optional instruct for fine-tuning (must use supported values only)
  order        Int      @default(0)
  active       Boolean  @default(true)
  voice        Voice    @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Track {
  id          String   @id @default(cuid())
  name        String   // e.g. "Corporativo", "Eletrônica", "Acústica"
  description String   @default("")
  emoji       String   @default("")
  category    String   @default("")
  audioPath   String   // URL for the track file (PHP hosting)
  duration    Float    @default(0) // duration in seconds
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique // e.g. "enableVoiceUpload"
  value String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
