# VozPro - Environment Variables
# Copy this file to .env and fill in the values

# Database (PostgreSQL - use Neon, Supabase, or Vercel Postgres)
# On Vercel: Set this in Project Settings > Environment Variables
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Vercel Blob Storage (auto-configured on Vercel when you add Blob store)
# On Vercel: Automatically set when you enable Blob in your project
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Admin Authentication
ADMIN_PASSWORD="VozPro@2026"
JWT_SECRET="your-secret-key-change-in-production"

# HuggingFace VozPro Space URL
HF_SPACE_URL="https://k2-fsa-omnivoice.hf.space"

# Google OAuth (para login de clientes)
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# MercadoPago (para paywall de download)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxx-your-access-token"

# App URL (para webhooks do MercadoPago)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# SMTP (envio de audio por email)
# Para Gmail: ative Verificacao em 2 Etapas > crie App Password em
# https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"
EMAIL_FROM="VozPro <your-email@gmail.com>"

# ============================================================
# Vercel Deployment Notes:
# ============================================================
# 1. Create a PostgreSQL database (recommended: Neon at neon.tech)
# 2. Run `npx prisma migrate deploy` to set up tables
# 3. Enable Vercel Blob in your project dashboard
# 4. Set all env variables in Vercel Project Settings
# 5. The /api/generate route needs >60s timeout (requires Vercel Pro)
#    - On Vercel Hobby: maxDuration is capped at 60s
#    - On Vercel Pro: maxDuration can be up to 300s
# ============================================================
