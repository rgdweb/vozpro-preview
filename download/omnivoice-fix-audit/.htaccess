# Omnivoice - CORS e Seguranca (SEGURO para HostGator/LiteSpeed)
# AUDITORIA (18/05/2026):
# - CORRIGIDO: "Header always set" em vez de "Header set" (CORS em TODAS as respostas, inclusive erros)
# - CORRIGIDO: Sintaxe APENAS Apache 2.4 (sem mistura com 2.2)
# - SEM php_value (usa .user.ini no lugar - HostGator usa FastCGI)
# - SEM <Directory> (proibido em .htaccess)

# ===================== CORS (sempre enviado, em TODAS as respostas) =====================
<IfModule mod_headers.c>
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS, DELETE"
  Header always set Access-Control-Allow-Headers "Content-Type, X-Requested-With, Authorization, X-Upload-Token, X-Generate-Token, X-Chunk-Index, X-Total-Chunks, X-File-Name, X-File-Size"
</IfModule>

# ===================== Permitir acesso aos arquivos de audio =====================
<FilesMatch "\.(wav|mp3|ogg|flac|m4a|webm)$">
  Require all granted
</FilesMatch>

# ===================== Proteger arquivos sensiveis =====================
<Files "config.php">
  Require all denied
</Files>
<Files "tunnel-config.ini">
  Require all denied
</Files>

# ===================== Bloquear arquivos de dados/sistema (web access only) =====================
<FilesMatch "\.(ini|log|sh|bat|ps1|env|py)$">
  Require all denied
</FilesMatch>

# ===================== Bloquear PHP dentro da pasta de audios =====================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^audios/.*\.php$ - [F,L]
</IfModule>
